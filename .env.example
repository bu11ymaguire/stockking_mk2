# API 키 템플릿
# 이 파일을 복사해서 .env로 만든 뒤 실제 키를 입력하세요.
# .env 파일은 .gitignore에 포함되어 있어 커밋되지 않습니다.
#
# 사용법:
#   1) 이 파일을 .env로 복사:
#      copy .env.example .env   (Windows)
#      cp .env.example .env     (macOS/Linux)
#   2) AIza...로 시작하는 실제 키로 교체
#
# 발급 가이드:
#   https://aistudio.google.com/apikey
#   - 구글 계정으로 로그인
#   - "Create API key" 클릭
#   - 신용카드 등록 불필요 (무료 티어 사용 가능)

# Google Gemini API 키 (필수)
GOOGLE_API_KEY=AIza-your-gemini-key-here
